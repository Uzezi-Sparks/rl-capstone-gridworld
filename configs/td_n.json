{
  "algorithm": "TD-n",
  "type": "n-step forward-view TD control",
  "environment": "PursuitEvasionEnv",
  "hyperparameters": {
    "alpha": 0.1,
    "gamma": 0.9,
    "epsilon": 0.1,
    "n": 3,
    "n_episodes": 2000
